# LLM Provider API Keys (LiteLLM reads these automatically)
# Uncomment and set values for the providers you use.

# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# AZURE_API_KEY=
# ZAI_API_KEY=

# Local model server (if using Ollama)
# OLLAMA_API_BASE=http://localhost:11434

# Data directory (default: ./data)
DATA_DIR=./data

# Logging
LOG_LEVEL=INFO
