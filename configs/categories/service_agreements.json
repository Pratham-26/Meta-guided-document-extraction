        "properties": {
          "name": { "type": "string" },
          "type": {
            "type": ["string", "null"],
            "description": "corporation, LLC, LLP, PLLC, partnership, sole proprietorship, nonprofit, REIT, JPA"
          },
          "jurisdiction": {
            "type": ["string", "null"],
            "description": "state/country of incorporation/organization"
          },
          "address": { "type": ["string", "null"] },
          "signatory": { "type": ["string", "null"] },
          "signatory_title": { "type": ["string", "null"] },
          "signatory_date": {
            "type": ["string", "null"],
            "description": "ISO 8601 date"
          }
        }
      },
      "client": {
        "type": "object",
        "required": ["name"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "type": { "type": ["string", "null"] },
          "jurisdiction": { "type": ["string", "null"] },
          "address": { "type": ["string", "null"] },
          "signatory": { "type": ["string", "null"] },
          "signatory_title": { "type": ["string", "null"] },
          "signatory_date": {
            "type": ["string", "null"],
            "description": "ISO 8601 date"
          }
        }
      },
      "secondary_client": {
        "type": ["object", "null"],
        "description": "Additional party in multi-party agreements",
        "required": ["name"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "type": { "type": ["string", "null"] },
          "jurisdiction": { "type": ["string", "null"] },
          "address": { "type": ["string", "null"] },
          "signatory": { "type": ["string", "null"] },
          "signatory_title": { "type": ["string", "null"] },
          "signatory_date": {
            "type": ["string", "null"],
            "description": "ISO 8601 date"
          }
        }
      },
      "scope_of_services": {
        "type": "string",
        "description": "faithful description of services from the document"
      },
      "term": {
        "type": "object",
        "additionalProperties": false,
